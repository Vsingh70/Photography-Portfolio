{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vflics Studio",
  "version": "0.1.0",
  "identifier": "com.vflics.studio",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://vflics.com/studio?key=REPLACE_WITH_STUDIO_UPLOAD_TOKEN",
    "beforeBuildCommand": "",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "vflics Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "https://vflics.com/studio?key=REPLACE_WITH_STUDIO_UPLOAD_TOKEN",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
