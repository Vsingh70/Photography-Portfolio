{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vflics Studio",
  "version": "0.1.0",
  "identifier": "com.vflics.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000/studio",
    "beforeBuildCommand": "",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "vflics Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "http://localhost:3000/studio"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
