# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Tauri build artifacts
/src-tauri/target/
/src-tauri/gen/
/src-tauri/icons/icon.iconset/
/out/
# Local-only Tauri config override — contains the auth token in the URL,
# must never be committed. Copy `tauri.conf.json` to this filename and
# replace REPLACE_WITH_STUDIO_UPLOAD_TOKEN with your real token.
/src-tauri/tauri.conf.local.json

# Gallery variants live on Cloudflare R2 (see scripts/generate-gallery-data.ts).
# The local public/galleries/ folder is leftover from a previous strategy and
# should never be committed.
/public/galleries/

# The R2 sync manifests are tracked in git so incremental skips work across
# machines and CI. The gallery JSONs are tracked because Next.js bundles them
# at build time.
